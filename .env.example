# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# Database
DB_NAME=ipso_detector
DB_USER=ipso_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_WEBHOOK_SECRET=random-secret-string-for-webhook-validation

# OpenRouter API (for LLM narrative classification)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# DeepL API (primary translator, free tier key ends with :fx)
DEEPL_API_KEY=your-deepl-api-key-here

# Analysis thresholds
IPSO_SCORE_SAFE=0.35
IPSO_SCORE_SUSPICIOUS=0.70

# Feature flags
USE_CELERY=True
