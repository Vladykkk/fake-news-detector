@startuml use_case_diagram
' ІПСО Детектор — Діаграма варіантів використання (Use Case)

skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    ArrowColor #1565C0
}
skinparam actor {
    BackgroundColor #BBDEFB
    BorderColor #1565C0
}

left to right direction

actor "Telegram-\nкористувач" as TUser
actor "Веб-\nкористувач" as WUser
actor "API-клієнт" as AClient
actor "Адміністратор" as Admin

rectangle "Система IPSO Detector" {
    ' === Основні use cases ===
    usecase "Надіслати текст\nдля аналізу" as UC1
    usecase "Переглянути\nрезультат аналізу" as UC2
    usecase "Надати зворотний\nзв'язок (👍/👎)" as UC3
    usecase "Переглянути\nісторію аналізів" as UC4
    usecase "Переглянути\nстатистику" as UC5

    ' === Include use cases (внутрішні підпроцеси) ===
    usecase "Визначити мову\nта перекласти" as UC_Translate
    usecase "Аналіз риторичних\nтехнік (rule-based)" as UC_Rhetoric
    usecase "Класифікація\nнаративів (LLM)" as UC_Narrative
    usecase "Порівняння з базою\nвідомих ІПСО" as UC_Similarity
    usecase "Ансамблевий\nскоринг" as UC_Ensemble
    usecase "Збереження\nрезультату в БД" as UC_Save

    ' === Адмін use cases ===
    usecase "Управління базою\nвідомих наративів" as UC_Admin1
    usecase "Перегляд аналітики\nта моніторинг" as UC_Admin2
}

' Зовнішні системи
actor "OpenRouter\nAPI" as OpenRouter
actor "Google\nTranslate" as GoogleAPI

' === Зв'язки акторів ===
TUser --> UC1
TUser --> UC2
TUser --> UC3
TUser --> UC5

WUser --> UC1
WUser --> UC2
WUser --> UC4

AClient --> UC1
AClient --> UC4

Admin --> UC_Admin1
Admin --> UC_Admin2
Admin --> UC4

' === Include зв'язки ===
UC1 ..> UC_Translate : <<include>>
UC1 ..> UC_Rhetoric : <<include>>
UC1 ..> UC_Narrative : <<include>>
UC1 ..> UC_Similarity : <<include>>
UC1 ..> UC_Ensemble : <<include>>
UC1 ..> UC_Save : <<include>>

' === Зовнішні залежності ===
UC_Narrative --> OpenRouter
UC_Translate --> GoogleAPI

@enduml
