@startuml activity_diagram
' ІПСО Детектор — Діаграма діяльності (Activity)

skinparam activity {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    ArrowColor #1565C0
    DiamondBackgroundColor #FFF9C4
    DiamondBorderColor #F9A825
}

title Діаграма діяльності — Процес аналізу тексту на ознаки ІПСО

start

:Користувач надсилає текст
(Telegram / Веб / API);

:API Gateway приймає запит;

if (Текст ≥ 30 символів?) then (так)
else (ні)
    :Повернути помилку:
    "Текст замалий для аналізу";
    stop
endif

:Надіслати підтвердження
"🔍 Аналізую...";

:Створити задачу в черзі
(Celery → Redis);

|Analyzer Worker|

:Отримати задачу з черги Redis;

:Визначити мову тексту
(langdetect);

if (Мова = англійська?) then (так)
    :Використати оригінальний текст;
else (ні)
    :Перекласти на англійську
    (Google Translate API);
endif

fork
    :Аналіз риторичних технік
    (rule-based, regex);
    note right
        Whataboutism,
        хибний авторитет,
        нагнітання страху,
        деморалізація,
        хибна рівність,
        cherry-picking
    end note
fork again
    :Класифікація наративів
    (OpenRouter LLM API);
    note right
        7 категорій:
        деморалізація,
        підрив довіри,
        хибна рівність,
        паніка, втрати ЗСУ,
        "Захід зраджує",
        корупція
    end note
fork again
    :Семантичне порівняння
    з базою відомих ІПСО
    (cosine similarity);
end fork

:Ансамблевий скоринг
(narrative×0.40 + rhetoric×0.30 + similarity×0.30);

if (final_score > 0.70?) then (так)
    #FF8A80:Вердикт: 🚨 ІПСО;
elseif (final_score > 0.35?) then (так)
    #FFE082:Вердикт: ⚠️ Підозрілий;
else (ні)
    #C8E6C9:Вердикт: ✅ Безпечно;
endif

|API Gateway|

:Зберегти результат
у PostgreSQL;

:Сформувати відповідь
(Telegram HTML / JSON / Web);

:Відправити результат
користувачу;

if (Користувач натиснув\nкнопку зворотного зв'язку?) then (так)
    :Зберегти відгук
    (👍 Правильно / 👎 Помилка);
else (ні)
endif

stop

@enduml
