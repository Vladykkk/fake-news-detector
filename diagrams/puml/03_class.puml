@startuml class_diagram
' ІПСО Детектор — Діаграма класів (Class)

skinparam class {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    ArrowColor #1565C0
    HeaderBackgroundColor #BBDEFB
}

skinparam package {
    BackgroundColor #FAFAFA
    BorderColor #90A4AE
}

' ==============================
' Пакет: Ядро (моделі даних)
' ==============================
package "apps.core (Моделі даних)" {

    class AnalysisResult {
        - id: int <<PK>>
        - original_text: str
        - detected_language: str
        - translated_text: str
        - source: str {telegram, api, web}
        - narrative_score: float
        - rhetoric_score: float
        - similarity_score: float
        - final_score: float
        - verdict: str {safe, suspicious, ipso}
        - detected_narratives: JSON
        - detected_rhetoric: JSON
        - similar_narratives: JSON
        - processing_time_ms: int
        - created_at: datetime
        + __str__(): str
    }

    class TelegramAnalysis {
        - id: int <<PK>>
        - result: AnalysisResult <<FK>>
        - chat_id: int
        - message_id: int
        - username: str
        - created_at: datetime
    }

    class Feedback {
        - id: int <<PK>>
        - result: AnalysisResult <<FK>>
        - feedback_type: str {correct, wrong}
        - chat_id: int
        - created_at: datetime
    }

    class KnownNarrative {
        - id: int <<PK>>
        - title: str
        - description: str
        - category: str
        - example_texts: JSON
        - embedding: JSON
        - source: str
        - is_active: bool
        - created_at: datetime
        + __str__(): str
    }
}

' ==============================
' Пакет: Аналізатор (AI pipeline)
' ==============================
package "apps.analyzer (AI Pipeline)" {

    class AnalysisPipeline <<Orchestrator>> {
        + analyze(text: str, source: str): dict
        + analyze_and_save(text: str, source: str): AnalysisResult
        - get_verdict(score: float): str
    }

    class TranslatorModule {
        + detect_language(text: str): str
        + translate_to_english(text: str, source_lang: str): str
        + preprocess(text: str): dict
    }

    class RhetoricModule {
        - RHETORIC_PATTERNS: dict
        + analyze_rhetoric(text: str): dict
    }

    class NarrativeModule {
        - NARRATIVE_CANDIDATES: list
        - _classifier: object
        + analyze_narratives(text: str): dict
        - _classify_via_openrouter(text: str): dict
    }

    class SimilarityModule {
        - _model: SentenceTransformer
        + analyze_similarity(text: str): dict
        - cosine_similarity(vec_a: list, vec_b: list): float
        + compute_and_store_embeddings(): int
    }

    class AnalyzerConstants {
        + RHETORIC_PATTERNS: dict
        + NARRATIVE_LABELS: dict
        + THRESHOLD_SAFE: float = 0.35
        + THRESHOLD_SUSPICIOUS: float = 0.70
        + MIN_TEXT_LENGTH: int = 30
    }
}

' ==============================
' Пакет: Celery (асинхронні задачі)
' ==============================
package "apps.analyzer.tasks (Celery)" {

    class AnalyzeContentTask <<CeleryTask>> {
        - max_retries: int = 3
        - default_retry_delay: int = 5
        + run(text: str, chat_id: int, message_id: int, username: str, source: str): void
    }
}

' ==============================
' Пакет: Telegram Bot
' ==============================
package "apps.bot (Telegram Bot)" {

    class TelegramHandlers {
        + start_handler(update, context): void
        + help_handler(update, context): void
        + stats_handler(update, context): void
        + message_handler(update, context): void
        + callback_handler(update, context): void
    }

    class ResultFormatter {
        - VERDICT_EMOJI: dict
        - VERDICT_LABEL: dict
        - NARRATIVE_LABELS_UA: dict
        - RHETORIC_LABELS_UA: dict
        + format_result_message(result: AnalysisResult): str
    }

    class KeyboardBuilder {
        + feedback_keyboard(result_id: int): InlineKeyboardMarkup
    }

    class WebhookView <<DjangoView>> {
        + webhook_view(request): HttpResponse
        - _get_application(): Application
    }
}

' ==============================
' Пакет: REST API
' ==============================
package "apps.api (REST API)" {

    class AnalyzeView <<APIView>> {
        + post(request): Response
    }

    class HistoryView <<APIView>> {
        + get(request): Response
    }

    class AnalysisResultSerializer <<Serializer>> {
        + fields: list
    }

    class AnalyzeRequestSerializer <<Serializer>> {
        + text: CharField
    }
}

' ==============================
' Зв'язки
' ==============================

' Моделі
AnalysisResult "1" -- "0..1" TelegramAnalysis : result_id >
AnalysisResult "1" -- "0..*" Feedback : result_id >

' Pipeline orchestration
AnalysisPipeline ..> TranslatorModule : використовує
AnalysisPipeline ..> RhetoricModule : використовує
AnalysisPipeline ..> NarrativeModule : використовує
AnalysisPipeline ..> SimilarityModule : використовує
AnalysisPipeline ..> AnalyzerConstants : конфігурація
AnalysisPipeline ..> AnalysisResult : створює

' Similarity використовує KnownNarrative
SimilarityModule ..> KnownNarrative : порівнює embeddings

' Celery task використовує Pipeline
AnalyzeContentTask ..> AnalysisPipeline : делегує аналіз
AnalyzeContentTask ..> TelegramAnalysis : створює зв'язок
AnalyzeContentTask ..> ResultFormatter : форматує відповідь
AnalyzeContentTask ..> KeyboardBuilder : створює кнопки

' Bot handlers
TelegramHandlers ..> AnalyzeContentTask : .delay() через Celery
TelegramHandlers ..> AnalysisPipeline : (dev mode, sync)
WebhookView ..> TelegramHandlers : dispatch

' API views
AnalyzeView ..> AnalysisPipeline : аналіз
AnalyzeView ..> AnalysisResultSerializer : серіалізація
HistoryView ..> AnalysisResult : запит з БД

' Callback handler → Feedback
TelegramHandlers ..> Feedback : зберігає відгук

@enduml
