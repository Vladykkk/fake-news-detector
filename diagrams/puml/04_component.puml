@startuml component_diagram
' ІПСО Детектор — Діаграма компонентів (Component)

skinparam component {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    ArrowColor #1565C0
}
skinparam interface {
    BackgroundColor #BBDEFB
    BorderColor #1565C0
}
skinparam package {
    BackgroundColor #FAFAFA
    BorderColor #78909C
}
skinparam database {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}
skinparam cloud {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}

title Діаграма компонентів — IPSO Detector

' === Зовнішні актори ===
actor "Telegram\nкористувач" as TUser
actor "Веб\nкористувач" as WUser
actor "API\nклієнт" as AUser

' === Зовнішні сервіси ===
cloud "OpenRouter API\n(LLM)" as OpenRouter
cloud "Google Translate\nAPI" as GoogleAPI
cloud "Telegram\nBot API" as TelegramAPI

' === Головна система ===
package "IPSO Detector System" {

    ' --- API Gateway ---
    package "API Gateway (Django + Gunicorn)" {
        component [Webhook\nEndpoint] as Webhook
        component [REST API\n(DRF Views)] as RestAPI
        component [Веб-інтерфейс\n(Django Templates\n+ HTMX)] as WebUI
        component [Django Admin\nПанель] as AdminPanel
        component [URL Router] as Router

        interface "POST /bot/webhook/" as IWebhook
        interface "POST /api/analyze/" as IAnalyze
        interface "GET /api/history/" as IHistory
        interface "GET /web/" as IWeb
        interface "GET /admin/" as IAdmin
    }

    ' --- Reverse Proxy ---
    component [nginx\n(Reverse Proxy\n+ SSL)] as Nginx

    ' --- Message Broker ---
    component [Redis\n(Message Broker\n+ Cache)] as Redis

    ' --- Analyzer Workers ---
    package "Analyzer Workers (Celery)" {
        component [Translator\nModule] as Translator
        component [Rhetoric\nModule] as Rhetoric
        component [Narrative\nModule] as Narrative
        component [Similarity\nModule] as Similarity
        component [Analysis\nPipeline] as Pipeline
        component [Celery\nTask Runner] as TaskRunner
    }

    ' --- Telegram Bot ---
    package "Telegram Bot Service" {
        component [Command\nHandlers] as Handlers
        component [Result\nFormatter] as Formatter
        component [Keyboard\nBuilder] as Keyboard
    }

    ' --- Data Layer ---
    database "PostgreSQL" as PG {
        component [AnalysisResult] as TblResult
        component [KnownNarrative] as TblNarrative
        component [Feedback] as TblFeedback
        component [TelegramAnalysis] as TblTelegram
    }
}

' === Зв'язки: зовнішні користувачі → nginx ===
TUser --> Nginx : HTTPS
WUser --> Nginx : HTTPS
AUser --> Nginx : HTTPS

' === nginx → Django ===
Nginx --> IWebhook
Nginx --> IAnalyze
Nginx --> IHistory
Nginx --> IWeb
Nginx --> IAdmin

IWebhook --> Webhook
IAnalyze --> RestAPI
IHistory --> RestAPI
IWeb --> WebUI
IAdmin --> AdminPanel

' === Webhook → Bot Handlers ===
Webhook --> Handlers : dispatch update

' === Handlers → Celery ===
Handlers --> Redis : analyze_task.delay()
RestAPI --> Redis : analyze_task.delay()

' === Redis → Worker ===
Redis --> TaskRunner : deliver task

' === Pipeline orchestration ===
TaskRunner --> Pipeline
Pipeline --> Translator
Pipeline --> Rhetoric
Pipeline --> Narrative
Pipeline --> Similarity

' === Зовнішні API ===
Translator --> GoogleAPI : REST (translate)
Narrative --> OpenRouter : REST (classify)

' === Worker → DB ===
Pipeline --> PG : зберегти результат
Similarity --> TblNarrative : cosine similarity

' === Worker → Telegram ===
TaskRunner --> TelegramAPI : відправити результат
TaskRunner --> Formatter : форматування
TaskRunner --> Keyboard : inline buttons

' === Bot Handlers → DB ===
Handlers --> TblFeedback : зберегти відгук

' === API → DB ===
RestAPI --> PG : запити до БД
AdminPanel --> PG : CRUD операції

@enduml
