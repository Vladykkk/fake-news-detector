@startuml sequence_diagram
' ІПСО Детектор — Діаграма послідовності (Sequence)
' Сценарій: Telegram-користувач надсилає текст для аналізу

skinparam sequence {
    ArrowColor #1565C0
    LifeLineBorderColor #1565C0
    LifeLineBackgroundColor #E3F2FD
    ParticipantBackgroundColor #BBDEFB
    ParticipantBorderColor #1565C0
}

title Діаграма послідовності — Аналіз повідомлення через Telegram

actor "Telegram\nкористувач" as User
participant "Telegram\nBot API" as TgAPI
participant "nginx" as Nginx
participant "API Gateway\n(Django)" as Gateway
participant "Redis\n(Celery Broker)" as Redis
participant "Analyzer\nWorker" as Worker
participant "Google\nTranslate" as Google
participant "OpenRouter\n(LLM)" as OpenRouter
database "PostgreSQL" as DB

== Надсилання повідомлення ==

User -> TgAPI : Надіслати текст
activate TgAPI
TgAPI -> Nginx : POST /bot/webhook/\n(JSON Update)
activate Nginx
Nginx -> Gateway : proxy_pass :8003
activate Gateway

Gateway -> Gateway : Валідація webhook secret
Gateway -> Gateway : Перевірка довжини тексту (≥30)

Gateway -> User : "🔍 Аналізую..."
note right : Миттєва відповідь\n(≤300ms)

Gateway -> Redis : analyze_content_task.delay(\ntext, chat_id, message_id,\nusername, source)
activate Redis

Gateway --> Nginx : HTTP 200 OK
deactivate Gateway
deactivate Nginx
deactivate TgAPI

== Асинхронний аналіз (Celery Worker) ==

Redis -> Worker : Deliver task
activate Worker
deactivate Redis

Worker -> Worker : detect_language(text)\n→ "uk"

Worker -> Google : translate("uk" → "en")
activate Google
Google --> Worker : translated_text
deactivate Google

|||

group Паралельний аналіз [3 модулі]

    Worker -> Worker : analyze_rhetoric(translated)\n→ rhetoric_score, detections

    Worker -> OpenRouter : POST /chat/completions\n(classify narratives)
    activate OpenRouter
    OpenRouter --> Worker : narrative_labels + scores
    deactivate OpenRouter

    Worker -> Worker : analyze_similarity(translated)\n→ similarity_score, matches
    note right : Локальні embeddings\n(sentence-transformers\nMiniLM)

end

|||

Worker -> Worker : Ансамблевий скоринг:\nnarrative×0.40 +\nrhetoric×0.30 +\nsimilarity×0.30

Worker -> Worker : get_verdict(final_score)

Worker -> DB : INSERT AnalysisResult
activate DB
DB --> Worker : result_id
deactivate DB

Worker -> DB : INSERT TelegramAnalysis\n(result_id, chat_id, message_id)

== Відправка результату ==

Worker -> TgAPI : bot.send_message(\nchat_id, formatted_result,\nreply_markup=feedback_keyboard)
activate TgAPI
TgAPI -> User : 📊 Форматований результат\n+ кнопки 👍/👎
deactivate TgAPI

deactivate Worker

== Зворотний зв'язок (опціонально) ==

User -> TgAPI : Натискає 👍 або 👎
activate TgAPI
TgAPI -> Nginx : POST /bot/webhook/\n(CallbackQuery)
activate Nginx
Nginx -> Gateway : proxy_pass
activate Gateway

Gateway -> DB : INSERT Feedback\n(result_id, feedback_type)
Gateway -> TgAPI : "Дякуємо за відгук! 🙏"
TgAPI -> User : "Дякуємо за відгук! 🙏"

deactivate Gateway
deactivate Nginx
deactivate TgAPI

@enduml
