@startuml collaboration_diagram
' ІПСО Детектор — Діаграма кооперації (Communication/Collaboration)

skinparam object {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
    ArrowColor #1565C0
}

title Діаграма кооперації — Взаємодія об'єктів при аналізі тексту

object "user : TelegramUser" as User {
    chat_id = 123456789
    username = "user123"
}

object "gateway : APIGateway" as Gateway {
    port = 8003
    framework = Django
}

object "broker : Redis" as Redis {
    port = 6379
    role = "Message Broker"
}

object "worker : AnalyzerWorker" as Worker {
    concurrency = 2
    framework = Celery
}

object "pipeline : AnalysisPipeline" as Pipeline {
    weights = {0.40, 0.30, 0.30}
}

object "translator : TranslatorModule" as Translator {
    target_lang = "en"
}

object "rhetoric : RhetoricModule" as Rhetoric {
    patterns_count = 6
}

object "narrative : NarrativeModule" as Narrative {
    model = "OpenRouter LLM"
}

object "similarity : SimilarityModule" as Similarity {
    model = "MiniLM-L12-v2"
    threshold = 0.55
}

object "db : PostgreSQL" as DB {
    tables = 4
}

object "result : AnalysisResult" as Result {
    final_score = 0.82
    verdict = "ipso"
}

object "formatter : ResultFormatter" as Formatter {
    format = "HTML"
}

object "telegramAPI : TelegramBotAPI" as TgAPI {
    method = "sendMessage"
}

' === Пронумеровані повідомлення ===

User --> Gateway : 1. Надсилає текст через Telegram webhook
Gateway --> Redis : 2. analyze_content_task.delay(text, chat_id, ...)
Gateway --> User : 3. "🔍 Аналізую..." (миттєва відповідь)

Redis --> Worker : 4. Доставка задачі з черги
Worker --> Pipeline : 5. pipeline.analyze(text, source)

Pipeline --> Translator : 5.1. preprocess(text) → detect_language + translate
Pipeline --> Rhetoric : 5.2. analyze_rhetoric(translated_text)
Pipeline --> Narrative : 5.3. analyze_narratives(translated_text)
Pipeline --> Similarity : 5.4. analyze_similarity(translated_text)

Pipeline --> Result : 6. Створення результату (ensemble scoring)
Worker --> DB : 7. Збереження AnalysisResult + TelegramAnalysis

Worker --> Formatter : 8. format_result_message(result)
Worker --> TgAPI : 9. send_message(chat_id, formatted_text, keyboard)
TgAPI --> User : 10. Відображення результату з кнопками 👍/👎

User --> Gateway : 11. Натискає кнопку зворотного зв'язку
Gateway --> DB : 12. Збереження Feedback(result_id, type)

@enduml
