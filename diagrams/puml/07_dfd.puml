@startuml dfd_level0
' ІПСО Детектор — DFD Рівень 0 (Контекстна діаграма)

skinparam rectangle {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
}
skinparam agent {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}
skinparam database {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}

title DFD Рівень 0 — Контекстна діаграма системи IPSO Detector

' Зовнішні сутності
agent "Telegram-\nкористувач" as E1
agent "Веб-\nкористувач" as E2
agent "API-\nклієнт" as E3
agent "Адміністратор" as E4
agent "OpenRouter\nAPI (LLM)" as E5
agent "Google\nTranslate" as E6

' Головний процес
rectangle "  **0**\n  IPSO Detector\n  System  " as P0

' Сховище
database "D1: База\nрезультатів\nаналізу" as D1
database "D2: База\nвідомих\nнаративів" as D2

' Потоки даних
E1 -right-> P0 : текст повідомлення
P0 -left-> E1 : результат аналізу +\nзворотний зв'язок

E2 -right-> P0 : текст для аналізу
P0 -left-> E2 : результат + історія

E3 --> P0 : POST /api/analyze/
P0 --> E3 : JSON відповідь

E4 --> P0 : управління наративами
P0 --> E4 : статистика

P0 -right-> E5 : запит на\nкласифікацію
E5 -left-> P0 : наративні\nмітки + скори

P0 -right-> E6 : текст для\nперекладу
E6 -left-> P0 : перекладений\nтекст

P0 --> D1 : збереження\nрезультату
D1 --> P0 : історія\nаналізів

P0 --> D2 : оновлення\nембедінгів
D2 --> P0 : відомі\nнаративи

@enduml

' ============================================

@startuml dfd_level1
' ІПСО Детектор — DFD Рівень 1 (Декомпозиція)

skinparam rectangle {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
}
skinparam agent {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}
skinparam database {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}

title DFD Рівень 1 — Декомпозиція процесу аналізу

' Зовнішні сутності
agent "Telegram /\nВеб / API\nкористувач" as E_User
agent "OpenRouter\nAPI" as E_LLM
agent "Google\nTranslate" as E_GT
agent "Адміністратор" as E_Admin

' Сховища
database "D1: Результати\nаналізу" as D1
database "D2: Відомі\nнаративи" as D2
database "D3: Зворотний\nзв'язок" as D3

' Процеси
rectangle "  **1.0**\n  Прийом та\n  валідація\n  запиту  " as P1
rectangle "  **2.0**\n  Визначення\n  мови та\n  переклад  " as P2
rectangle "  **3.1**\n  Аналіз\n  риторичних\n  технік  " as P31
rectangle "  **3.2**\n  Класифікація\n  наративів\n  (LLM)  " as P32
rectangle "  **3.3**\n  Семантичне\n  порівняння\n  з базою  " as P33
rectangle "  **4.0**\n  Ансамблевий\n  скоринг та\n  вердикт  " as P4
rectangle "  **5.0**\n  Збереження\n  та відповідь  " as P5
rectangle "  **6.0**\n  Обробка\n  зворотного\n  зв'язку  " as P6

' Потоки
E_User --> P1 : вхідний текст
P1 --> E_User : помилка\n(текст замалий)

P1 --> P2 : валідований текст

P2 --> E_GT : текст для\nперекладу
E_GT --> P2 : перекладений\nтекст

P2 --> P31 : англійський текст
P2 --> P32 : англійський текст
P2 --> P33 : англійський текст

P32 --> E_LLM : запит на\nкласифікацію
E_LLM --> P32 : наративні мітки

D2 --> P33 : відомі наративи\n+ embeddings

P31 --> P4 : rhetoric_score\n+ detections
P32 --> P4 : narrative_score\n+ detections
P33 --> P4 : similarity_score\n+ matches

P4 --> P5 : final_score +\nverdict + деталі

P5 --> D1 : збереження\nрезультату
P5 --> E_User : форматований\nрезультат

E_User --> P6 : 👍/👎 відгук
P6 --> D3 : збереження\nвідгуку

E_Admin --> D2 : CRUD\nнаративів

@enduml
