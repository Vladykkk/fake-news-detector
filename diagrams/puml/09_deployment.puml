@startuml deployment_diagram
' ІПСО Детектор — Діаграма розгортання (Deployment)

skinparam node {
    BackgroundColor #E3F2FD
    BorderColor #1565C0
}
skinparam component {
    BackgroundColor #BBDEFB
    BorderColor #1565C0
}
skinparam database {
    BackgroundColor #E8F5E9
    BorderColor #2E7D32
}
skinparam cloud {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}
skinparam artifact {
    BackgroundColor #FCE4EC
    BorderColor #C62828
}

title Діаграма розгортання — IPSO Detector (DigitalOcean)

' === Клієнтські вузли ===
node "Клієнтські пристрої" as Clients {
    artifact "Telegram\n(iOS / Android / Desktop)" as TgClient
    artifact "Веб-браузер\n(Chrome / Firefox)" as Browser
    artifact "API-клієнт\n(Postman / curl / SDK)" as APIClient
}

' === Зовнішні хмарні сервіси ===
cloud "Зовнішні сервіси" as External {
    node "Telegram\nBot API" as TelegramCloud {
        component [api.telegram.org\nHTTPS REST] as TgAPIServer
    }
    node "OpenRouter\nAI Platform" as OpenRouterCloud {
        component [openrouter.ai/api\nHTTPS REST\n(LLM inference)] as ORServer
    }
    node "Google\nTranslate" as GoogleCloud {
        component [translate.googleapis.com\nHTTPS REST] as GTServer
    }
}

' === Серверний вузол (DigitalOcean) ===
node "DigitalOcean Droplet\nUbuntu 24.04 LTS\n2 vCPU / 2GB RAM / 50GB SSD\nFrankfurt (FRA1)" as Server {

    ' --- Reverse Proxy ---
    node "nginx :80/:443" as NginxNode {
        component [nginx\nReverse Proxy\n+ Let's Encrypt SSL] as NginxComp
    }

    ' --- Application Layer ---
    node "Application Layer" as AppLayer {

        node "Gunicorn :8003\n(3 workers)" as GunicornNode {
            component [Django 4.2\n+ DRF] as DjangoComp
            component [Webhook View\n(POST /bot/webhook/)] as WebhookComp
            component [REST API Views\n(POST /api/analyze/\nGET /api/history/)] as APIComp
            component [Web UI\n(Django Templates\n+ HTMX)] as WebComp
            component [Django Admin] as AdminComp
        }

        node "Celery Worker #1" as CeleryNode1 {
            component [AnalysisPipeline] as Pipeline1
            component [TranslatorModule] as Trans1
            component [RhetoricModule] as Rhet1
            component [NarrativeModule] as Narr1
            component [SimilarityModule\n(sentence-transformers\nMiniLM-L12-v2)] as Sim1
        }

        node "Celery Worker #2" as CeleryNode2 {
            component [AnalysisPipeline] as Pipeline2
            note right : Ідентичний Worker #1\n(горизонтальне\nмасштабування)
        }
    }

    ' --- Data Layer ---
    node "Data Layer" as DataLayer {

        database "PostgreSQL 16\n:5432" as PGNode {
            component [analysis_result] as T1
            component [telegram_analysis] as T2
            component [feedback] as T3
            component [known_narrative] as T4
        }

        database "Redis 7\n:6379" as RedisNode {
            component [Celery Broker\n(task queue)] as RedisBroker
            component [Result Backend\n(task results)] as RedisResults
        }
    }
}

' === Мережеві з'єднання ===

' Клієнти → nginx
TgClient --> TgAPIServer : HTTPS
TgAPIServer --> NginxComp : HTTPS POST\n(webhook)
Browser --> NginxComp : HTTPS
APIClient --> NginxComp : HTTPS

' nginx → Django
NginxComp --> DjangoComp : HTTP :8003\n(proxy_pass)

' Django → Redis (задачі)
DjangoComp --> RedisBroker : TCP :6379\n(Celery .delay())

' Redis → Workers
RedisBroker --> Pipeline1 : AMQP\n(deliver task)
RedisBroker --> Pipeline2 : AMQP\n(deliver task)

' Workers → зовнішні API
Narr1 --> ORServer : HTTPS\n(POST /chat/completions)
Trans1 --> GTServer : HTTPS\n(translate)

' Workers → DB
Pipeline1 --> PGNode : TCP :5432\n(INSERT result)
Pipeline2 --> PGNode : TCP :5432

' Workers → Telegram
Pipeline1 --> TgAPIServer : HTTPS\n(sendMessage)

' Django → DB
DjangoComp --> PGNode : TCP :5432\n(Django ORM)

' Results
Pipeline1 --> RedisResults : TCP :6379\n(task result)

@enduml
